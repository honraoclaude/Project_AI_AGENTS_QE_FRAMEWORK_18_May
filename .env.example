# Copy to .env and fill in values — never commit .env to source control

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ─────────────────────────────────────────────────────────────────
# Admin URL (migrations only — never used by application services)
DATABASE_ADMIN_URL=postgresql+psycopg://qe_admin:localdev@localhost:5432/qe_framework
# Writer URL (Fleet Commander, MCP servers, Sign-off service)
DATABASE_URL=postgresql+psycopg://qe_agent_writer:writer_localdev@localhost:5432/qe_framework
# Reader URL (Audit queries, Inspector interface)
DATABASE_READER_URL=postgresql+psycopg://qe_audit_reader:reader_localdev@localhost:5432/qe_framework

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Jira ─────────────────────────────────────────────────────────────────────
JIRA_URL=https://yourfirm.atlassian.net
JIRA_USERNAME=qe-automation@yourfirm.com
JIRA_API_TOKEN=...
JIRA_PROJECT_KEY=FSC

# ── Salesforce (Wave 1 — simplified Describe API only) ───────────────────────
SF_USERNAME=qe-automation@yourfirm.sandbox
SF_PASSWORD=...
SF_SECURITY_TOKEN=...
SF_DOMAIN=test

# ── Sign-off service ─────────────────────────────────────────────────────────
SIGNOFF_BASE_URL=http://localhost:8000
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SIGNOFF_HMAC_SECRET=change-me-generate-a-real-secret
SIGNOFF_LINK_EXPIRY_HOURS=48

# ── Azure Communication Services (email) ─────────────────────────────────────
AZURE_COMM_CONNECTION_STRING=endpoint=https://...
AZURE_COMM_SENDER=qe-framework@yourfirm.internal

# ── Model selection ───────────────────────────────────────────────────────────
DEFAULT_MODEL=claude-sonnet-4-6
HIGH_STAKES_MODEL=claude-opus-4-7
FAST_MODEL=claude-haiku-4-5-20251001
CONFIDENCE_ESCALATION_THRESHOLD=60

# ── Compliance contacts ───────────────────────────────────────────────────────
COMPLIANCE_OFFICER_EMAIL=compliance@yourfirm.com
QE_LEAD_EMAIL=qe-lead@yourfirm.com
TECH_LEAD_EMAIL=tech-lead@yourfirm.com
